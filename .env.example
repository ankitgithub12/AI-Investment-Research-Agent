# ─── Server .env (place in server/.env) ───

PORT=5000
NODE_ENV=development

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# Google Gemini — https://aistudio.google.com
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tavily Search — https://tavily.com
TAVILY_API_KEY=

# NewsAPI (optional) — https://newsapi.org
NEWS_API_KEY=

# Client URL for CORS (set to your deployed frontend URL in production)
CLIENT_URL=http://localhost:5173

# Financial Modeling Prep
FMP_API_KEY=
FINANCIAL_PROVIDER=fmp
CACHE_DURATION=600
MAX_RETRIES=4
REQUEST_TIMEOUT=10000

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash




# ─── Client .env (place in client/.env) ───

# Backend API URL — leave empty for dev (Vite proxy handles it)
# In production, set to your deployed backend URL, e.g.:
# VITE_API_URL=https://your-api.onrender.com
VITE_API_URL=
